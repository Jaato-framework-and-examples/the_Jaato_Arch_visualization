# jaato daemon env for the python-sdk examples.
# No secret here: the OpenRouter credential is supplied as a `pass:` resolver
# knob of the provider plugin (plugin_configs.openrouter.api_key =
# "pass://jaato/openrouter/api-key"), in _config.py's AUTH and in each
# declarative profile — never as an env var, never in a tracked file.
#
# These two lines just name the provider + model the examples run against. The
# comparison docs show `gpt-4o` / `openai`; the examples substitute a cheap,
# locally-funded OpenRouter model. See README.md ("Standing substitutions").

JAATO_PROVIDER=openrouter
MODEL_NAME=openai/gpt-4o-mini
