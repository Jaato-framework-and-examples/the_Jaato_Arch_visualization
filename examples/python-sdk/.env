# jaato daemon env for the python-sdk examples.
# Provider auth is NOT here — the zhipuai credential resolves from
# `stored:zhipuai-auth` (~/.jaato/zhipuai_auth.json) on this host, so no
# secret is ever written into a tracked file.
#
# These two lines just name the provider + model the examples run against.
# The comparison docs show `gpt-4o` / `openai`; the examples substitute the
# locally-reachable GLM model so they actually round-trip end to end. See
# README.md ("Standing deviations from the docs").

JAATO_PROVIDER=zhipuai
MODEL_NAME=glm-5-turbo
